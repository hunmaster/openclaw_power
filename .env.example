# ============================================
# YouTube 댓글 자동화 프로그램 설정
# ============================================
# 이 파일을 .env로 복사한 후 값을 채워주세요
# cp .env.example .env

# --- Notion API 설정 ---
# Notion Integration 토큰 (https://www.notion.so/my-integrations 에서 생성)
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 데이터베이스 ID (URL에서 추출)
# 예: https://www.notion.so/30d35cfd83d38006935dc23424bce256?v=xxx
# → 데이터베이스 ID: 30d35cfd83d38006935dc23424bce256
NOTION_DATABASE_ID=30d35cfd83d38006935dc23424bce256

# --- Notion DB 컬럼명 설정 ---
# 유튜브 링크가 있는 컬럼명
NOTION_COLUMN_YOUTUBE_URL=유튜브 링크
# 댓글 원고가 있는 컬럼명
NOTION_COLUMN_COMMENT_TEXT=댓글 원고
# 댓글 작성 후 URL을 저장할 컬럼명
NOTION_COLUMN_COMMENT_RESULT_URL=댓글 URL
# 작업 상태를 저장할 컬럼명
NOTION_COLUMN_STATUS=상태
# 사용할 계정명 컬럼 (선택)
NOTION_COLUMN_ACCOUNT=계정

# --- YouTube 계정 설정 ---
# 계정 정보 파일 경로 (JSON)
ACCOUNTS_FILE=config/accounts.json

# --- 프록시 설정 (부계정 IP 관리) ---
# 프록시 사용 여부 (true/false)
USE_PROXY=false
# 프록시 목록 파일 경로
PROXY_LIST_FILE=config/proxies.txt
# 프록시 로테이션 방식: sequential(순차) / random(랜덤)
PROXY_ROTATION=sequential

# --- 브라우저 설정 ---
# 브라우저 헤드리스 모드 (true=화면없이 / false=화면보이기)
HEADLESS=false
# 댓글 작성 후 대기 시간 (초) - 너무 빠르면 봇으로 의심
DELAY_AFTER_COMMENT=5
# 계정 전환 시 대기 시간 (초) - IP 변경 대기
DELAY_AFTER_IP_CHANGE=3
# 페이지 로드 대기 시간 (초)
PAGE_LOAD_TIMEOUT=30
