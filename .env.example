# ============================================
# CommentBoost - 유튜브 댓글 자동화 프로그램 설정
# ============================================
# 이 파일을 .env 로 복사한 후 값을 채워주세요.
# 대부분의 설정은 대시보드(localhost:5000)에서 변경할 수 있습니다.

# --- 라이선스 / 운영 모드 ---
# client = 고객 모드 (기본값, 라이선스 검증 필수)
# owner = 개발자 모드 (OWNER_SECRET_KEY 인증 필수)
LICENSE_MODE=client
LICENSE_SERVER_URL=https://api.commentboost.cloud
# Owner 모드 사용 시 관리자로부터 발급받은 시크릿 키 (일반 사용자는 비워두세요)
# OWNER_SECRET_KEY=

# --- 관리자 비밀키 (필수) ---
# 관리자 모드 진입 시 사용되는 비밀키입니다. 반드시 설정해주세요.
ADMIN_SECRET_KEY=

# --- 업데이트 서버 (기본값 사용 권장) ---
# UPDATE_SERVER_URL=https://commentboost-app.fly.dev

# --- Notion API 설정 ---
# 대시보드 셋업 위자드에서도 설정 가능합니다.
# Notion Integration 토큰 (https://www.notion.so/my-integrations 에서 생성)
NOTION_API_TOKEN=
# Notion 데이터베이스 ID (URL에서 추출: notion.so/xxxxxxxxxx?v=... 에서 xxxxxxxxxx 부분)
NOTION_DATABASE_ID=

# --- Notion DB 컬럼명 설정 ---
# 제공된 Notion 템플릿을 사용하면 아래 설정을 변경할 필요 없습니다.
NOTION_COLUMN_YOUTUBE_URL=영상 링크
NOTION_COLUMN_COMMENT_TEXT=댓글 원고
NOTION_COLUMN_COMMENT_RESULT_URL=댓글 url
NOTION_COLUMN_STATUS=상태
NOTION_COLUMN_ACCOUNT=댓글 계정

# --- YouTube 계정 설정 ---
ACCOUNTS_FILE=config/accounts.json

# --- 프록시 설정 (선택) ---
USE_PROXY=false
PROXY_LIST_FILE=config/proxies.txt
PROXY_ROTATION=sequential

# --- ADB IP 변경 설정 (선택 - 안드로이드 폰 USB 테더링 사용 시) ---
ADB_IP_CHANGE_ENABLED=false
ADB_PATH=adb
ADB_AIRPLANE_WAIT=4
ADB_AUTO_ETHERNET=true

# --- 브라우저 설정 ---
HEADLESS=false
DELAY_AFTER_COMMENT=5
DELAY_AFTER_IP_CHANGE=3
PAGE_LOAD_TIMEOUT=30

# --- 안전 규칙 설정 ---
MAX_COMMENTS_PER_DAY=20
SAME_VIDEO_INTERVAL_MIN=30
COMMENT_INTERVAL_SEC=180

# --- SMM 좋아요 자동 구매 (선택) ---
SMM_ENABLED=false
SMM_API_KEY=
SMM_LIKE_SERVICE_ID=4001
SMM_LIKE_QUANTITY=20

# --- Lemon Squeezy 결제 설정 ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=

# --- Lemon Squeezy 구독 플랜 체크아웃 URL ---
LEMONSQUEEZY_CHECKOUT_STARTER=https://commentboost-ai.lemonsqueezy.com/checkout/buy/30b27fd0-7037-4a07-b57e-ef6f9de7c227
LEMONSQUEEZY_CHECKOUT_BUSINESS=https://commentboost-ai.lemonsqueezy.com/checkout/buy/c8fb4c61-2fc5-4eae-8a97-5585e8c37c4e
LEMONSQUEEZY_CHECKOUT_AGENCY=https://commentboost-ai.lemonsqueezy.com/checkout/buy/39eee6ef-dc49-4184-ac23-38af4150e573

# --- Lemon Squeezy 좋아요 크레딧 체크아웃 URL ---
LEMONSQUEEZY_CHECKOUT_LIKE_5000=https://commentboost-ai.lemonsqueezy.com/checkout/buy/3c0f7ce6-3a69-44bd-8696-8779f1e81839
LEMONSQUEEZY_CHECKOUT_LIKE_10000=https://commentboost-ai.lemonsqueezy.com/checkout/buy/5821b2a9-2460-4e48-8c52-1d5cf3975dc6
LEMONSQUEEZY_CHECKOUT_LIKE_30000=https://commentboost-ai.lemonsqueezy.com/checkout/buy/a6ef8e7b-a7c8-42c1-942c-7d255a9754ac
